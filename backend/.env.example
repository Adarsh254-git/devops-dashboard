# Copy to .env and adjust. Never commit real secrets.

PORT=5000

# GitHub (existing)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Groq (optional)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# MongoDB
# Local Node (mongod on your machine):
MONGODB_URI=mongodb://127.0.0.1:27017/devops-dashboard
# Docker Compose (must use service hostname `database`, not localhost):
# MONGODB_URI=mongodb://database:27017/devops-dashboard

# Set to true to boot API without Mongo (limited features)
# SKIP_DB=true

# Auth (required for register/login)
JWT_SECRET=change-this-to-a-long-random-string
# JWT_EXPIRES_IN=7d
